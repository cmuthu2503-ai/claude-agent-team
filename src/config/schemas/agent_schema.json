{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Configuration",
  "type": "object",
  "required": ["agent_id", "display_name", "role", "team", "model", "responsibilities", "tools", "outputs", "delegation", "metadata"],
  "properties": {
    "agent_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]+$",
      "description": "Unique snake_case identifier"
    },
    "display_name": { "type": "string", "minLength": 1 },
    "role": { "type": "string", "minLength": 1 },
    "team": {
      "type": "string",
      "enum": ["engineering", "planning", "development", "delivery"]
    },
    "reports_to": {
      "oneOf": [
        { "type": "string" },
        { "type": "null" }
      ]
    },
    "model": {
      "type": "string",
      "enum": ["claude-opus-4-6", "claude-sonnet-4-6"]
    },
    "system_prompt": { "type": "string", "minLength": 10 },
    "responsibilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description", "category"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Z]+-\\d+$" },
          "description": { "type": "string" },
          "category": {
            "type": "string",
            "enum": ["planning", "development", "review", "testing", "deployment"]
          }
        }
      }
    },
    "tools": {
      "type": "array",
      "items": { "type": "string" }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "format"],
        "properties": {
          "name": { "type": "string" },
          "format": {
            "type": "string",
            "enum": ["markdown", "json", "yaml", "code", "report"]
          }
        }
      }
    },
    "delegation": {
      "type": "object",
      "required": ["can_delegate_to", "max_concurrent_tasks"],
      "properties": {
        "can_delegate_to": {
          "type": "array",
          "items": { "type": "string" }
        },
        "max_concurrent_tasks": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        }
      }
    },
    "quality_gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["gate_id", "description"],
        "properties": {
          "gate_id": { "type": "string" },
          "description": { "type": "string" },
          "threshold": { "type": "string" }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["created", "version"],
      "properties": {
        "created": { "type": "string" },
        "version": { "type": "string" }
      }
    }
  }
}
