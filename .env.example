# Anthropic API (used when provider="anthropic")
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Amazon Bedrock (used when provider="bedrock")
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Optional: temporary credentials
AWS_SESSION_TOKEN=
# Optional: override the Bedrock model ID (default: anthropic.claude-sonnet-4-20250514-v1:0)
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0

# OpenAI API (used when provider="openai_gpt5" or provider="openai_o3")
OPENAI_API_KEY=sk-xxxxx
# Optional: override the model IDs the OpenAI provider uses
# Defaults: gpt-5.4 (latest flagship, 2026-03-05) and o4-mini (latest reasoning, 2025-04-16)
OPENAI_GPT5_MODEL_ID=gpt-5.4
OPENAI_O3_MODEL_ID=o4-mini

# Database
DATABASE_URL=sqlite:///data/agent_team.db

# GitHub Integration (PAT with contents:write scope, used by ResearchPublisher)
GITHUB_TOKEN=ghp_xxxxx
GITHUB_REPO=cmuthu2503-ai/claude-agent-team
GITHUB_BRANCH=main

# Firecrawl (used by web_search and web_scrape tools — gives agents live web access)
FIRECRAWL_API_KEY=fc-xxxxx

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Environment
ENVIRONMENT=development
LOG_LEVEL=DEBUG
