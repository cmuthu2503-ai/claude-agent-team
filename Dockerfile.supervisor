FROM docker:27-cli

# Install Python and curl
RUN apk add --no-cache python3 py3-pip curl git

WORKDIR /app

COPY supervisor/deploy_supervisor.py ./deploy_supervisor.py

# The supervisor needs access to:
# 1. Docker socket (to run docker compose commands)
# 2. SQLite database (to read/write deployment_state)
# 3. Project source (to run git commands)

HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
    CMD pgrep -f deploy_supervisor || exit 1

CMD ["python3", "/app/deploy_supervisor.py"]
